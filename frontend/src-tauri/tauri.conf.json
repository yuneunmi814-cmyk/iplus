{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iPlus",
  "version": "0.1.0",
  "identifier": "ai.iplus.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iPlus",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: https://asset.localhost data:",
        "connect-src": "'self' http://localhost:8787 http://127.0.0.1:8787 http://localhost:11434 https://api.ollama.ai"
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/iplus-engine"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": "-",
      "hardenedRuntime": true
    },
    "windows": {
      "signCommand": "powershell -ExecutionPolicy Bypass -File scripts/sign-windows.ps1 -FilePath %1"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMkVGNjBGNzkzNTM0MzIKUldReU5EVjVEL1l1WHpyVWh6d3MrbW5XS3gvWjJuV0JwYTBMaVZ5bGt2dk9PMERrcnFSdFRYMGYK",
      "endpoints": [
        "https://github.com/yuneunmi814-cmyk/iplus/releases/latest/download/latest.json"
      ]
    }
  }
}
