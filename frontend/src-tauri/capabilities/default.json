{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "iPlus main window permissions — run the engine sidecar + update/store/notify",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:app:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/iplus-engine", "sidecar": true, "args": true }]
    },
    "updater:default",
    "process:default",
    "store:default",
    "fs:default",
    "dialog:default",
    "notification:default"
  ]
}
